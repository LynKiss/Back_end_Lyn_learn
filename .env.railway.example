PORT=3001
API_PREFIX=api/v1
# Nhiều domain: phân tách bằng dấu phẩy (vd: https://app.vercel.app,https://www.app.com)
CORS_ORIGIN=https://your-vercel-app.vercel.app
# Production: tắt Swagger để không lộ schema API.
ENABLE_SWAGGER=false
NODE_ENV=production

# Railway MySQL plugin usually provides MYSQLHOST, MYSQLPORT, MYSQLUSER,
# MYSQLPASSWORD and MYSQLDATABASE automatically. DB_* still works if you prefer
# manual variables.
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true
DB_LOGGING=false

JWT_ACCESS_SECRET=replace-with-long-random-string-access
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-long-random-string-refresh
JWT_REFRESH_EXPIRES_IN=7d

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
SUPPORT_BOT_API_KEY=
SUPPORT_BOT_MODEL=gemini-2.5-flash
SUPPORT_BOT_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
SUPPORT_BOT_TIMEOUT_MS=10000
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=26214400

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=web_lyn
