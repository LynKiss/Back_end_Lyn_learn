# App
PORT=3001
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_mysql_password
DB_NAME=web_lyn
# Migration là nguồn chân lý. Để false và dùng migration (khuyến nghị mọi môi trường).
DB_SYNCHRONIZE=false
# Tự chạy migration đang chờ khi app khởi động (tiện cho deploy).
DB_MIGRATIONS_RUN=true
DB_LOGGING=false

# JWT (đổi sang chuỗi ngẫu nhiên dài khi deploy)
JWT_ACCESS_SECRET=replace-with-long-random-string-access
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-long-random-string-refresh
JWT_REFRESH_EXPIRES_IN=7d

# AI (điền khi triển khai feature AI ở M3+)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
SUPPORT_BOT_API_KEY=
SUPPORT_BOT_MODEL=gemini-2.5-flash
SUPPORT_BOT_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
SUPPORT_BOT_TIMEOUT_MS=10000
WHISPER_API_KEY=
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Local uploads
UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=26214400
